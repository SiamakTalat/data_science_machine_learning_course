      "source": [
        "# 13 — Solutions: Finance Data Capstone Project\n",
        "\n",
        "This notebook contains the complete solutions for the Finance Data Capstone Project. Each cell corresponds to a specific task or step in the original project notebook."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 1 — Setup"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from pandas_datareader import data, wb",
        "import pandas as pd",
        "import numpy as np",
        "import datetime",
        "import matplotlib.pyplot as plt",
        "import seaborn as sns",
        "%matplotlib inline"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 2 — Get Data"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "start = datetime.datetime(2006,1,1)",
        "end = datetime.datetime(2016,1,1)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "BAC = data.DataReader('BAC', 'stooq', start, end)",
        "C = data.DataReader('C', 'stooq', start, end)",
        "GS = data.DataReader('GS', 'stooq', start, end)",
        "JPM = data.DataReader('JPM', 'stooq', start, end)",
        "MS = data.DataReader('MS', 'stooq', start, end)",
        "WFC = data.DataReader('WFC', 'stooq', start, end)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 3 — Combine into MultiIndex"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "tickers = ['BAC','C','GS','JPM','MS','WFC']",
        "bank_stocks = pd.concat([BAC,C,GS,JPM,MS,WFC], axis=1, keys=tickers)"
      ]
    },
    {
	  "cell_type": "code",
	  "execution_count": null,
	  "metadata": {},
	  "outputs": [],
	  "source": [
		"bank_stocks.columns.names = ['Bank Ticker','Stock Info']"
	  ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 4 — Basic Stock EDA"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Identify max close price\n",
        "bank_stocks['Close'].max()\n",
        "\n",
        "# Identify biggest daily drop\n",
        "bank_stocks['Close'].pct_change().min()\n",
        "\n",
        "# Identify biggest daily gain\n",
        "bank_stocks['Close'].pct_change().max()\n",
        "\n",
        "# Determine the riskiest stock (highest volatility)\n",
        "bank_stocks['Close'].pct_change().std()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 5 — Returns"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "returns = pd.DataFrame()"
        "for tick in tickers:\n",
        "    returns[tick + ' Return'] = bank_stocks[tick]['Close'].pct_change()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 6 — Pairplots"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "sns.pairplot(returns[1:].dropna())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 7 — Distribution Analysis"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 2015 Morgan Stanley returns distribution\n",
        "sns.histplot(returns.loc['2015']['MS Return'], bins=50)",
        "\n",
        "# 2008 Citigroup returns distribution\n",
        "sns.histplot(returns.loc['2008']['C Return'], bins=50, color='red')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 8 — Closing Price Trends"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "bank_stocks.xs(key='Close', axis=1, level='Stock Info').plot(figsize=(12,4))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 9 — Moving Averages"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "BAC_close = bank_stocks.xs(key='Close', axis=1, level='Stock Info')['BAC']\n",
        "BAC_close.loc['2008-01-01':'2009-01-01'].rolling(window=30).mean().plot(label='30 Day MA')\n",
        "BAC_close.loc['2008-01-01':'2009-01-01'].plot(label='BAC Close')",
        "plt.legend()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Part 10 — Correlation Heatmap"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "sns.heatmap(bank_stocks.xs(key='Close', axis=1, level='Stock Info').corr(), annot=True)",
        "\n",
        "sns.clustermap(bank_stocks.xs(key='Close', axis=1, level='Stock Info').corr())"
      ]
    }
  ]
}